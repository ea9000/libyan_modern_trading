  { "fieldname": "receipt_no", "fieldtype": "Data", "label": "رقم الواصل", "reqd": 1 },
  { "fieldname": "receipt_photo", "fieldtype": "Attach Image", "label": "وصل الاستلام" },
  { "fieldname": "section_financial", "fieldtype": "Section Break", "label": "التفاصيل المالية" },
  { "fieldname": "payment_type", "fieldtype": "Select", "label": "نوع التحصيل", "options": "نقد\nصك\nتحويل", "default": "نقد" },
  { "fieldname": "bank", "fieldtype": "Link", "label": "المصرف", "options": "Bank Account" },
  { "fieldname": "column_break_2", "fieldtype": "Column Break" },
  { "fieldname": "agent_commission", "fieldtype": "Currency", "label": "نسبة المندوب", "read_only": 1 },
  { "fieldname": "agent_percentage", "fieldtype": "Float", "label": "نسبة المندوب (%)", "read_only": 1 },
  { "fieldname": "section_stats", "fieldtype": "Section Break", "label": "إحصائيات" },
  { "fieldname": "sum_percentages", "fieldtype": "Currency", "label": "مجموع النسبة", "read_only": 1 },
