  { "fieldname": "posting_date", "fieldtype": "Datetime", "label": "تاريخ الاستلام", "default": "Now", "read_only": 1 },
  { "fieldname": "customer", "fieldtype": "Link", "label": "أسم الزبون", "options": "Customer" },
  { "fieldname": "column_break_1", "fieldtype": "Column Break" },
