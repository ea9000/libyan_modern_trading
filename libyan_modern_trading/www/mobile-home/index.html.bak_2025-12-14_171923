{% extends "templates/web.html" %}

{% block header %}{% endblock %}
{% block footer %}{% endblock %}
{% block title %}{% endblock %}

{% block page_content %}

<script>
  window.ACTIVE_KEY = "home";
  window.PAGE_TITLE  = "Mobile Home";
</script>

<link rel="stylesheet" href="/assets/libyan_modern_trading/css/app_shell.css">
<script defer src="/assets/libyan_modern_trading/js/app_shell.js"></script>

<link rel="stylesheet" href="/assets/libyan_modern_trading/css/mobile_home.css">

<div class="appshell" id="appShell">

  <!-- TOP BAR -->
  <div class="topbar" id="appTopbar">
    <div class="topbar-right">
      <button class="icon-btn" id="btnMenu" type="button" aria-label="Menu">☰</button>

      <img id="companyLogo" class="company-logo"
           src="/assets/libyan_modern_trading/images/logo.png"
           alt="Logo" onerror="this.style.display='none';">

      <div class="topbar-title" id="topbarTitle">Mobile Home</div>
    </div>

    <div class="topbar-left">
      <button class="icon-btn" id="btnRefresh" type="button" aria-label="Refresh">⟳</button>
      <button class="icon-btn" id="btnSearch" type="button" aria-label="Search">🔍</button>
    </div>
  </div>

  <!-- DRAWER -->
  <div class="drawer-overlay hidden" id="drawerOverlay"></div>

  <aside class="drawer hidden" id="drawer">
    <div class="drawer-header">
      <div class="drawer-title">Libyan Modern Trading</div>
      <div class="drawer-sub">{{ frappe.session.user }}</div>
    </div>

    <div class="drawer-list">
      <a class="drawer-item" href="/mobile-settings">⚙️ Settings</a>
      <a class="drawer-item" href="/mobile-report">✉️ Sales Report (Tripoli)</a>
      <a class="drawer-item" href="/mobile-simple-report">📋 Simple Report</a>
      <a class="drawer-item" href="/mobile-orders-closed">📌 Closed Orders</a>
    </div>

    <div class="drawer-footer">
      <a class="drawer-logout" href="/?cmd=web_logout">Logout</a>
    </div>
  </aside>

  <!-- MAIN CONTENT (only scroll area) -->
  <div class="content" id="appContent">

    <div class="home-grid">
      <div class="card" onclick="location.href='/mobile-orders'">
        <div class="card-title">Orders</div>
        <div class="card-sub">Create / Edit</div>
      </div>

      <div class="card" onclick="location.href='/mobile-collections'">
        <div class="card-title">Collections</div>
        <div class="card-sub">Payments</div>
      </div>
    </div>

  </div>

  <!-- BOTTOM NAV -->
  <nav class="bottom-nav" id="bottomNav">
    <div class="nav-item" id="navReport" data-key="report">📄<br>Report</div>
    <div class="nav-item" id="navCustomers" data-key="customers">👤<br>Customers</div>
    <div class="nav-item" id="navOrders" data-key="orders">🛒<br>Orders</div>
    <div class="nav-item" id="navDebt" data-key="debt">💰<br>Debt</div>
  </nav>

</div>

<script>
  // Home does not have search; hide search button to avoid confusion
  document.addEventListener("DOMContentLoaded", function(){
    var s = document.getElementById("btnSearch");
    if (s) s.style.display = "none";
  });
</script>

{% endblock %}
