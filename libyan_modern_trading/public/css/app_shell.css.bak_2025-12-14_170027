/* =========================================================
   LMT APP SHELL (COMPATIBLE)
   - Fixes missing bottom nav by supporting old + new class names
   - Stabilizes layout without breaking existing JS selectors
   ========================================================= */

:root{
  --topbar-h: 52px;
  --bottomnav-h: 56px;
}

html, body{
  margin: 0;
  padding: 0;
  background: #f8f9fa;
}

/* ---- Shell container: support both ids/classes ---- */
#appShell,
.appshell{
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  background: #f8f9fa;
}

/* ---- Topbar: support both ids/classes ---- */
#appTopbar,
.topbar,
.mobile-topbar{
  height: var(--topbar-h);
  flex: 0 0 var(--topbar-h);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 10px;
  border-bottom: 1px solid #ddd;
  background: #ffffff;
  z-index: 1100;
}

#appTopbar .title,
.topbar .title,
.mobile-topbar .title{
  font-weight: 700;
  font-size: 18px;
}

#appTopbar .icon-btn,
.topbar .icon-btn,
.mobile-topbar .icon-btn{
  width: 34px;
  height: 34px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #ddd;
  background: #fff;
  border-radius: 8px;
  cursor: pointer;
}

/* ---- Scroll area: support both ids/classes ---- */
#appContent,
.content{
  flex: 1 1 auto;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 12px;
  background: #f8f9fa;
}

/* ---- Drawer overlay: keep your existing names ---- */
.drawer-overlay{
  position: fixed;
  top: var(--topbar-h);
  left: 0;
  right: 0;
  bottom: var(--bottomnav-h);
  background: rgba(0,0,0,0.25);
  display: none;
  z-index: 1200;
}
.drawer{
  position: fixed;
  top: var(--topbar-h);
  left: 0;
  bottom: var(--bottomnav-h);
  width: 280px;
  max-width: 85vw;
  background: #fff;
  border-right: 1px solid #ddd;
  transform: translateX(-105%);
  transition: transform .2s ease;
  z-index: 1300;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.drawer.open{ transform: translateX(0); }
.drawer-overlay.open{ display: block; }

.drawer-item{
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  cursor: pointer;
}
.drawer-sub{
  margin-top: 6px;
  color:#666;
  font-size:12px;
  direction:ltr;
  text-align:right;
}
.drawer-footer{
  padding: 12px 16px;
  border-top: 1px solid #eee;
}

/* ---- Bottom nav: support BOTH old and new selectors ---- */
#appBottomNav,
.bottom-nav,
.mobile-bottom-nav{
  height: var(--bottomnav-h);
  flex: 0 0 var(--bottomnav-h);
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1px solid #ddd;
  background: #ffffff;
  z-index: 1100;
}

/* item */
.bottom-nav-item,
.mobile-bottom-nav-item{
  flex: 1;
  text-align: center;
  font-size: 11px;
  line-height: 1.2;
  cursor: pointer;
}

.bottom-nav-item .icon,
.mobile-bottom-nav-item .icon{
  display: block;
  font-size: 18px;
  margin-bottom: 2px;
}

/* Alert */
.lmt-alert-actions{
  display:flex;
  justify-content: flex-start;
  margin-top: 14px;
}

/* =========================================================
   ERPNext wrapper neutralizer (SAFE)
   Avoid aggressive container resets that can break layout.
   ========================================================= */
body .page-head,
body .page-title,
body .page-head-content{
  display: none !important;
  height: 0 !important;
  margin: 0 !important;
  padding: 0 !important;
}

/* Keep ERPNext wrappers from adding top gap (minimal) */
body .main-section,
body .page-content-wrapper,
body .page-container,
body .page-content{
  margin: 0 !important;
  padding-top: 0 !important;
}

/* =========================================================
   Bottom nav - REAL markup support (.bottom-nav .nav-item)
   ========================================================= */
.bottom-nav{
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: var(--bottomnav-h);
  border-top: 1px solid #ddd;
  background: #fff;
  z-index: 1100;
}

.bottom-nav .nav-item{
  flex: 1;
  text-align: center;
  font-size: 11px;
  line-height: 1.2;
  cursor: pointer;
  padding: 6px 0;
  user-select: none;
}

.bottom-nav .nav-icon{
  display: block;
  font-size: 18px;
  margin-bottom: 2px;
}
